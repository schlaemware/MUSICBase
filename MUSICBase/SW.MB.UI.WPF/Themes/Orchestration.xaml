<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

  <!-- FOREGROUNDS -->
  <SolidColorBrush x:Key="ForegroundBrush" Color="{DynamicResource Foreground}" />
  <SolidColorBrush x:Key="LightForegroundBrush" Color="{DynamicResource LightForeground}" />
  <SolidColorBrush x:Key="DarkForegroundBrush" Color="{DynamicResource DarkForeground}" />

  <!-- BACKGROUNDS -->
  <SolidColorBrush x:Key="BackgroundBrush" Color="{DynamicResource Background}" />
</ResourceDictionary>
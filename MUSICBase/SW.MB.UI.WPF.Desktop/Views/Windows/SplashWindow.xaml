<Window x:Class="SW.MB.UI.WPF.Desktop.Views.Windows.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:p="clr-namespace:SW.MB.UI.WPF.Desktop.Properties"
        xmlns:local="clr-namespace:SW.MB.UI.WPF.Desktop.Views.Windows"
        mc:Ignorable="d"
        Title="SplashWindow"
        Height="450" Width="800"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None">

  <Grid>
    <Label Content="{x:Static p:Resources.AppTitle}" />
  </Grid>
</Window>
